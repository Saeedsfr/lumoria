# ═══════════════════════════════════════════════════
#   Lumoria — Environment Variables Example
# ═══════════════════════════════════════════════════

# ── Telegram Bot ────────────────────────────────────
BOT_TOKEN=your_bot_token_here
WEBAPP_URL=https://your-vercel-app.vercel.app

# ── TON Testnet ─────────────────────────────────────
TON_ENDPOINT=https://testnet.toncenter.com/api/v2/jsonRPC
# کلید API از https://toncenter.com/api/v2/ (اختیاری ولی rate limit بدون اون خیلی کمه)
TON_API_KEY=your_toncenter_api_key

# آدرس کیف پول ادمین (بعد از دپلوی پر می‌شه)
ADMIN_WALLET=your_admin_wallet_address

# ── Frontend Vite Env ────────────────────────────────
# این‌ها در frontend/.env می‌روند
VITE_TON_API_KEY=your_toncenter_api_key
VITE_APP_URL=https://your-vercel-app.vercel.app

# ── Database ─────────────────────────────────────────
DB_PATH=./data/lumoria.db
