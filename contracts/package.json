{
  "name": "lumoria-contracts",
  "version": "2.0.0",
  "description": "Lumoria Game Smart Contracts — TON/Tact",
  "scripts": {
    "build": "npx blueprint build",
    "test": "jest --testPathPattern='.*\\.spec\\.ts$' --forceExit",
    "deploy": "npx blueprint run scripts/deployAll.ts",
    "gen-wallet": "npx ts-node scripts/genWallet.ts",
    "deploy:testnet": "npx ts-node scripts/deployMnemonic.ts",
    "upgrade": "npx blueprint run scripts/upgrade.ts"
  },
  "keywords": [
    "ton",
    "tact",
    "lumoria",
    "gamefi"
  ],
  "license": "MIT",
  "devDependencies": {
    "@tact-lang/compiler": "^1.5.0",
    "@ton/blueprint": "^0.44.2",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "@ton/sandbox": "^0.43.0",
    "@ton/test-utils": "^0.12.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0"
  }
}
